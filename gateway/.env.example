# Cloudflare DDNS 설정
# 이 파일을 복사해 .env 로 만들고 값을 채워주세요.
# cp .env.example .env

# Cloudflare에 등록한 최상위 도메인 (Zone 이름)
CF_ZONE_NAME=

# Cloudflare API 토큰 (Edit zone DNS 권한 필요)
CF_API_TOKEN=

# 업데이트할 DNS A 레코드 목록
# 형식: 도메인|proxied여부 를 쉼표로 구분
# proxied=true  → Cloudflare 프록시 경유 (HTTP/HTTPS 서비스 권장)
# proxied=false → DNS only, 실제 IP 노출 (SSH 등 비HTTP 서비스)
CF_RECORDS=example.com|false,git.example.com|true
